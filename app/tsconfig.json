{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": [
      "dom",
      "esnext"
    ],
    "resolveJsonModule": true,
    "typeRoots": [
      "./types",
      "../node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    ".expo",
    "web-build",
    "dist"
  ],
  "extends": "../node_modules/expo/tsconfig.base.json"
}