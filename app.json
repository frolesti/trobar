{
  "expo": {
    "name": "troBar",
    "slug": "trobar-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./app/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trobar.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aquesta app necessita la teva ubicació per trobar bars a prop.",
        "NSPhotoLibraryUsageDescription": "Aquesta app necessita accés a la teva galeria per canviar la foto de perfil.",
        "NSCameraUsageDescription": "Aquesta app necessita accés a la teva càmera per fer fotos de perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.trobar.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCJDfdnUcgcc_AUyXPnEdHStmuNsUAZtb0"
        }
      }
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app necessita accés a les teves fotos per actualitzar el perfil."
        }
      ],
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyCJDfdnUcgcc_AUyXPnEdHStmuNsUAZtb0"
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "scheme": "trobar"
  }
}
