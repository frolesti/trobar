  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.3.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
