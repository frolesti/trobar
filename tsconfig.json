{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "lib": [
      "dom",
      "esnext"
    ],
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "app/*": [
        "app/*"
      ],
      "app/src/*": [
        "app/src/*"
      ],
      "app/src/screens/*": [
        "app/src/screens/*"
      ],
      "app/src/navigation/*": [
        "app/src/navigation/*"
      ],
      "app/src/services/*": [
        "app/src/services/*"
      ],
      "app/src/theme/*": [
        "app/src/theme/*"
      ],
      "app/src/context/*": [
        "app/src/context/*"
      ]
    },
    "typeRoots": [
      "./app/types",
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    ".expo",
    "web-build",
    "dist"
  ],
  "extends": "expo/tsconfig.base"
}